generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
}

model Favorite {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  movieId     Int
  title       String
  posterPath  String?
  releaseDate String?
  overview    String?
  userId      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([movieId, userId])
  @@index([userId])
}
